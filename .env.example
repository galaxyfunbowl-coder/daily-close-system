# Database (Prisma)
DATABASE_URL="file:./data/app.db"

# Session secret for auth
SESSION_SECRET="change-me-in-production"

# myDATA (AADE) - server-side only, never exposed to client
MYDATA_USER_ID=your_mydata_user_id
MYDATA_SUBSCRIPTION_KEY=your_subscription_key
MYDATA_BASE_URL=https://mydatapi.aade.gr
MYDATA_PATH=/myDATA/RequestMyExpenses
MYDATA_TIMEOUT_MS=60000
