generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../data/app.db"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  passwordHash String
  createdAt DateTime @default(now())
}

model Day {
  id          String   @id @default(cuid())
  date        String   @unique
  notes       String?
  isClosed    Boolean  @default(false)
  zPosTotal   Float?
  zCashTotal  Float?
  revenueLines RevenueLine[]
  partyEvents PartyEvent[]
}

model RevenueLine {
  id           String               @id @default(cuid())
  dayId        String
  day          Day                  @relation(fields: [dayId], references: [id], onDelete: Cascade)
  department   Department
  subLabel     String?
  subLabelInfo String?
  staffId      String?
  staff        Staff?               @relation(fields: [staffId], references: [id], onDelete: SetNull)
  operatorId   String?
  operator     ElectronicOperator?  @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  total        Float
  cash         Float
}

model PartyEvent {
  id            String        @id @default(cuid())
  dayId         String
  day           Day           @relation(fields: [dayId], references: [id], onDelete: Cascade)
  staffId       String
  staff         Staff         @relation(fields: [staffId], references: [id])
  total         Float
  paymentMethod PaymentMethod
  posInput      Float?
  posComputed   Float
  cashComputed  Float
  notes         String?
}

model Expense {
  id               String          @id @default(cuid())
  date             String
  invoiceNumber    String?
  supplierId       String?
  supplier         Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  category         String
  amount           Float
  paymentMethod    String
  notes            String?
  imagePath        String?
  source           String?         // "MYDATA" when imported from myDATA
  userEdited       Boolean         @default(false)
  myDataExpenseId  String?         @unique
  myDataExpense    MyDataExpense?  @relation(fields: [myDataExpenseId], references: [id], onDelete: SetNull)
}

model MyDataExpense {
  id                    String    @id @default(cuid())
  mark                  String    @unique
  uid                   String?
  issuerVat             String?
  issuerName            String?
  receiverVat           String?
  issueDate             DateTime?
  invoiceType           String?
  series                String?
  aa                    String?
  netAmount             Float?
  vatAmount             Float?
  totalAmount           Float?
  currency              String?
  cancellationMark      String?
  isCancelled           Boolean   @default(false)
  sourceRaw             String?   // JSON string for debugging
  attachmentPath        String?
  attachmentOriginalName String?
  attachmentMime        String?
  attachmentUploadedAt  DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  expense               Expense?
}

model Staff {
  id                 String               @id @default(cuid())
  name               String
  role               StaffRole            @default(SERVER)
  active             Boolean              @default(true)
  revenueLines       RevenueLine[]
  partyEvents        PartyEvent[]
  monthlySalaries    StaffMonthlySalary[]
}

model StaffMonthlySalary {
  id        String  @id @default(cuid())
  staffId   String
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  month     String  // YYYY-MM
  amount    Float
  @@unique([staffId, month])
}

model FixedMonthlyExpense {
  id     String @id @default(cuid())
  month  String // YYYY-MM
  name   String
  amount Float
}

model ElectronicOperator {
  id          String        @id @default(cuid())
  name        String
  active      Boolean       @default(true)
  revenueLines RevenueLine[]
}

model Supplier {
  id              String   @id @default(cuid())
  name            String
  defaultCategory String
  vatNumber       String?
  expenses        Expense[]
}

model Holiday {
  id   String @id @default(cuid())
  date String @unique
  name String
}

model Closure {
  id     String @id @default(cuid())
  date   String @unique
  reason String
}

model CompanySettings {
  id                    String   @id @default("main")
  companyVat            String?
  mydataUserId          String?
  mydataSubscriptionKey String?
  updatedAt             DateTime @updatedAt
}

enum Department {
  RECEPTION_BOWLING
  PAIDOTOPOS
  BILIARDA
  ELECTRONIC_GAMES
  BAR
  SERVICE
  PROSHOP
}

enum PaymentMethod {
  CASH
  CARD
  SPLIT
}

enum StaffRole {
  SERVER
  ADMIN
}
